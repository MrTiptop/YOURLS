# YOURLS Configuration
YOURLS_SITE=http://localhost:8080
YOURLS_PORT=8080

# Database Configuration
YOURLS_DB_HOST=db
YOURLS_DB_USER=yourls
YOURLS_DB_PASS=yourls_password
YOURLS_DB_NAME=yourls
YOURLS_DB_PREFIX=yourls_
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

# YOURLS Settings
YOURLS_LANG=
YOURLS_UNIQUE_URLS=true
YOURLS_PRIVATE=true
YOURLS_URL_CONVERT=36
YOURLS_DEBUG=false

# Admin Credentials (will be hashed automatically by YOURLS)
YOURLS_USER=admin
YOURLS_PASS=admin

# Cookie Key (generate a random string)
# You can generate one with: openssl rand -hex 32
YOURLS_COOKIEKEY=change-this-to-a-random-string
